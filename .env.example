# NeonDB (PostgreSQL)
DATABASE_URL=postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/silververse?sslmode=require

# Cloudflare R2 Storage
R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=silververse-uploads
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Flutterwave
FLW_PUBLIC_KEY=your-flutterwave-public-key
FLW_SECRET_KEY=your-flutterwave-secret-key
FLW_ENCRYPTION_KEY=your-flutterwave-encryption-key
FLW_BASE_URL=https://api.flutterwave.com/v3
FLW_WEBHOOK_SECRET=

# Server
PORT=3000
