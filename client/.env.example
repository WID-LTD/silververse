# ═══════════════════════════════════════
# SilverVerse — Client Environment Variables
# Copy this to client/.env and fill in values
# ═══════════════════════════════════════

# Local dev server port (for client/server.js proxy)
CLIENT_PORT=5050

# API base URL (local dev: http://localhost:10000, production: leave blank — Vercel proxy handles it)
API_URL=http://localhost:10000
