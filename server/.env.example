# ═══════════════════════════════════════
# SilverVerse — Server Environment Variables
# Copy this to server/.env and fill in values
# ═══════════════════════════════════════

# ── Server ──
PORT=10000
NODE_ENV=production

# ── CORS ──
CORS_ORIGIN=https://silververses.vercel.app

# ── Database (NeonDB PostgreSQL) ──
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Session ──
SESSION_SECRET=your-random-session-secret-here

# ── Admin ──
ADMIN_PASSWORD=your-admin-password-here

# ── Cloudflare R2 (Profile Image Storage) ──
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=silververse-uploads
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# ── Flutterwave (Payment Gateway) ──
FLW_PUBLIC_KEY=your-flutterwave-public-key
FLW_SECRET_KEY=your-flutterwave-secret-key
FLW_ENCRYPTION_KEY=your-flutterwave-encryption-key
FLW_WEBHOOK_SECRET=your-flutterwave-webhook-secret
FLW_CALLBACK_URL=https://silververses.vercel.app/payment-success.html
